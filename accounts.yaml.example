# DashScope 账户配置
# 这份文件是 DashScope API Key 的唯一来源 — 由开发/运维管理，UI 上不可见、不可改。
# 服务启动时读取本文件并与 DB 对账（按 name 匹配）。
# 复制为 accounts.yaml 后编辑，accounts.yaml 已在 .gitignore 中。
#
# 字段说明：
#   endpoint      — 提交任务的基础 URL（POST /services/...）
#   queryEndpoint — 查询任务结果的基础 URL（GET /tasks/{request_id}），可选
#                   不填则使用 endpoint。某些代理（如 sprize）的提交和查询
#                   走不同前缀路径，必须显式指定。
#   apiKey        — Bearer token
#
# 常见 endpoint:
#   https://ai.sprize.ai/proxy/dashscope-v2  (sprize 中转 — 默认推荐)
#     ↳ 配套 queryEndpoint: https://ai.sprize.ai/proxy
#   https://dashscope-intl.aliyuncs.com      (官方新加坡)
#   https://dashscope.aliyuncs.com           (官方北京)
#   https://dashscope-us.aliyuncs.com        (官方弗吉尼亚)
# 官方直连时不需要 queryEndpoint，代码会自动按 aliyuncs.com 规则处理。

accounts:
  - name: 主号
    apiKey: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
    endpoint: https://ai.sprize.ai/proxy/dashscope-v2
    queryEndpoint: https://ai.sprize.ai/proxy
    # disableDataInspection 默认为 true（关掉 DashScope 服务端内容审查），
    # 写 false 才会重新启用审查。
    # disableDataInspection: false
    # policy:                        # 可选，覆盖默认调度策略
    #   maxConcurrentRunning: 8
    #   submitRatePerMin: 30

  # - name: 备号 (官方新加坡直连)
  #   apiKey: sk-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
  #   endpoint: https://dashscope-intl.aliyuncs.com
