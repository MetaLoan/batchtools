# DashScope 账户配置
# 这份文件是 DashScope API Key 的唯一来源 — 由开发/运维管理，UI 上不可见、不可改。
# 服务启动时读取本文件并与 DB 对账（按 name 匹配）。
# 复制为 accounts.yaml 后编辑，accounts.yaml 已在 .gitignore 中。
#
# 可选 endpoint:
#   https://dashscope-intl.aliyuncs.com  (新加坡 — 默认)
#   https://dashscope.aliyuncs.com       (北京)
#   https://dashscope-us.aliyuncs.com    (弗吉尼亚)
# Key 在哪个地域申请的，必须配对应 endpoint，否则会报 InvalidApiKey。

accounts:
  - name: 主号
    apiKey: sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
    endpoint: https://dashscope-intl.aliyuncs.com
    # disableDataInspection: false   # 可选，默认 false
    # policy:                        # 可选，覆盖默认调度策略
    #   maxConcurrentRunning: 8
    #   submitRatePerMin: 30

  # - name: 备用号
  #   apiKey: sk-yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy
  #   endpoint: https://dashscope.aliyuncs.com
