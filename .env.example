# Server
PORT=3000
HOST=0.0.0.0
DATA_DIR=./data

# Public-facing host (used to build upload signed URLs that DashScope can fetch)
PUBLIC_HOST=http://localhost:3000

# Initial admin (only used on first start, when no users exist yet)
# After the first start, manage users via the UI; these vars are ignored.
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=changeme123

# Session lifetime
SESSION_TTL_DAYS=30

# Crypto master key for encrypting account API keys & signing upload URLs.
# Generate one with: openssl rand -hex 32
MASTER_KEY=replace-with-a-long-random-string

# Upload limits
UPLOAD_MAX_BYTES=26214400
UPLOAD_TTL_HOURS=24
