{
  "name": "batch-video-promoter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "pnpm --filter=./shared build && pnpm -r --parallel --filter=./server --filter=./web dev",
    "dev:server": "pnpm --filter=./shared build && pnpm --filter=./server dev",
    "dev:web": "pnpm --filter=./shared build && pnpm --filter=./web dev",
    "build": "pnpm --filter=./shared build && pnpm --filter=./web build && pnpm --filter=./server build",
    "start": "node server/dist/server.js",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
