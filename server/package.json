    "@fastify/static": "^7.0.4",
    "archiver": "^8.0.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.34.0",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.7",
    "p-queue": "^8.0.1",
    "undici": "^6.19.8",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.5.5",
